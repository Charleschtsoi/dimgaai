# Copy to .env in project root or backend/

# Required for live transcription
DEEPGRAM_API_KEY=

# LLM provider: openai | anthropic | gemini (gemini recommended - 2 keys)
LLM_PROVIDER=gemini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# PDF / RAG embeddings (Gemini stack). Legacy text-embedding-004 is deprecated.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# For anthropic only: openai | google (google recommended for embeddings)
EMBEDDING_PROVIDER=google

# Optional web search fallback
TAVILY_API_KEY=

# Storage
CHROMA_PERSIST_DIR=./data/chroma
UPLOAD_DIR=./data/uploads

# Server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000
STATIC_DIR=./static
HOST=0.0.0.0
PORT=8000

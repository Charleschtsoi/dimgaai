# Copy to .env in project root or backend/

# Required for live transcription
DEEPGRAM_API_KEY=

# LLM provider: openai | anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional web search fallback
TAVILY_API_KEY=

# Storage
CHROMA_PERSIST_DIR=./data/chroma
UPLOAD_DIR=./data/uploads

# Server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000
STATIC_DIR=./static
HOST=0.0.0.0
PORT=8000
